body{
  margin:0;
  font-family:Arial,sans-serif;
  background:#f2f2f2;
}

header{
  background:#1565C0;
  color:white;
  padding:35px 20px;
  text-align:center;
}

header h1{
  margin:0 0 15px 0;
  font-size:40px;
}

header p{
  margin:0 0 20px 0;
  font-size:18px;
}

#search,
#categoryFilter{
  width:90%;
  display:block;
  margin:20px auto;
  padding:14px;
  font-size:18px;
  border:1px solid #ccc;
  border-radius:10px;
  background:white;
  box-sizing:border-box;
}

#favoritesFilter{
  display:block;
  width:90%;
  margin:15px auto 25px auto;
  padding:14px;
  border:none;
  border-radius:12px;
  background:#e91e63;
  color:white;
  font-size:18px;
  font-weight:bold;
  cursor:pointer;
}

#darkModeBtn{
  padding:12px 20px;
  border:none;
  border-radius:10px;
  background:#222;
  color:white;
  font-size:18px;
  cursor:pointer;
}

.song,
.song-detail{
  background:white;
  margin:20px;
  padding:25px;
  border-radius:18px;
  box-shadow:0 4px 15px rgba(0,0,0,.12);
  position:relative;
}

.song h2,
.song-detail h2{
  margin-top:55px;
  font-size:32px;
}

.favorite-btn{
  position:absolute;
  top:20px;
  right:20px;
  border:none;
  background:transparent;
  font-size:34px;
  cursor:pointer;
}

.back-btn,
.projection-btn{
  display:inline-block;
  margin:0 10px 20px 0;
  padding:14px 20px;
  border:none;
  border-radius:12px;
  color:white;
  font-size:18px;
  font-weight:bold;
  cursor:pointer;
}

.back-btn{
  background:#1565c0;
}

.projection-btn{
  background:#111;
}

.transpose-box,
.font-box,
.scroll-box{
  display:flex;
  justify-content:center;
  align-items:center;
  gap:20px;
  margin:20px 0;
}

.transpose-box button,
.font-box button,
.scroll-box button{
  width:58px;
  height:58px;
  border:none;
  border-radius:50%;
  color:white;
  font-size:24px;
  font-weight:bold;
  cursor:pointer;
  box-shadow:0 3px 8px rgba(0,0,0,.25);
}

.transpose-box button,
.font-box button{
  background:#1565c0;
}

.scroll-box button{
  background:#333;
}

.transpose-box span,
.font-box span{
  font-size:26px;
  font-weight:bold;
}

.lyrics-text,
.song pre{
  white-space:pre-wrap;
  word-wrap:break-word;
  overflow-wrap:break-word;
  max-width:100%;
  font-family:monospace;
}

.lyrics-text{
  line-height:1.35;
}

.dark-mode{
  background:#121212;
  color:white;
}

.dark-mode header{
  background:#111;
}

.dark-mode .song,
.dark-mode .song-detail{
  background:#1e1e1e;
  color:white;
}

.dark-mode input,
.dark-mode select{
  background:#2b2b2b;
  color:white;
  border:1px solid #555;
}

.projection-mode{
  background:#000;
}

.projection-mode header,
.projection-mode #search,
.projection-mode #categoryFilter,
.projection-mode #favoritesFilter,
.projection-mode .projection-btn,
.projection-mode .back-btn,
.projection-mode .favorite-btn,
.projection-mode .song-detail h2,
.projection-mode .song-meta,
.projection-mode .chords-line,
.projection-mode .transpose-box,
.projection-mode .font-box,
.projection-mode .scroll-box{
  display:none !important;
}

.projection-mode main{
  margin:0;
  padding:0;
}

.projection-mode .song-detail{
  background:#000;
  color:white;
  box-shadow:none;
  margin:0;
  padding:30px;
  border-radius:0;
  min-height:100vh;
}

.projection-mode .lyrics-text{
  color:white;
  font-size:38px !important;
  line-height:1.45;
  margin:0;
}
/* ================= Splash Screen ================= */

#splashScreen{
    position:fixed;
    inset:0;
    background:#1565c0;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    z-index:9999;
    transition:opacity .6s ease;
}

#splashScreen.hide{
    opacity:0;
    pointer-events:none;
}

#splashScreen img{
    width:180px;
    height:180px;
    margin-bottom:20px;
    animation:logoFloat 2s infinite ease-in-out;
}

#splashScreen h1{
    color:white;
    font-size:40px;
    margin:0;
}

#splashScreen p{
    color:white;
    opacity:.9;
    margin-top:8px;
    font-size:18px;
}

@keyframes logoFloat{
    0%{transform:translateY(0);}
    50%{transform:translateY(-10px);}
    100%{transform:translateY(0);}
}

/* ================= Planificador ================= */

#plannerBtn{
    width:100%;
    padding:18px;
    margin:15px 0;
    border:none;
    border-radius:14px;
    background:#1565c0;
    color:white;
    font-size:22px;
    font-weight:bold;
    cursor:pointer;
    box-shadow:0 4px 10px rgba(0,0,0,.2);
}

#planName{
    width:100%;
    padding:14px;
    margin:15px 0;
    border-radius:10px;
    border:1px solid #ccc;
    font-size:16px;
}

.planner-action{
    width:100%;
    padding:15px;
    border:none;
    border-radius:12px;
    background:#1565c0;
    color:white;
    font-size:18px;
    font-weight:bold;
}

/* ================= AdorApp v1.5 ================= */

.plan-card,
.plan-song{
    background:white;
    margin:14px 0;
    padding:16px;
    border-radius:14px;
    box-shadow:0 3px 10px rgba(0,0,0,.12);
}

.plan-song h3{
    margin:0 0 8px 0;
}

.plan-song button,
.plan-card button{
    margin:5px 4px 0 0;
    padding:9px 12px;
    border:none;
    border-radius:9px;
    background:#1565c0;
    color:white;
    font-weight:bold;
}

.plan-song button:last-child,
.plan-card button{
    background:#d32f2f;
}

.share-plan-btn{
    background:#25D366 !important;
}

.cult-header{
    text-align:center;
    padding:10px;
    border-radius:12px;
    background:#1565c0;
    color:white;
    margin-bottom:15px;
}

.cult-nav{
    display:flex;
    gap:10px;
    justify-content:center;
    margin-top:20px;
}

.cult-nav button{
    flex:1;
}

.recent-box{
    background:#e3f2fd;
    padding:12px;
    border-radius:12px;
    margin:15px 0;
}

.dark-mode .plan-card,
.dark-mode .plan-song{
    background:#1e1e1e;
    color:white;
}

.dark-mode .recent-box{
    background:#263238;
    color:white;
}


/* ================= AdorApp v1.6 ================= */

.cult-mode-screen{
    min-height:100vh;
}

.plan-song p strong{
    color:#1565c0;
}

.dark-mode .plan-song p strong{
    color:#90caf9;
}



/* ================= AdorApp v1.8 - Modo Culto PRO ================= */

.cult-pro-active header,
.cult-pro-active main > input,
.cult-pro-active main > select,
.cult-pro-active #favoritesFilter,
.cult-pro-active #plannerBtn{
    display:none !important;
}

.cult-pro-screen{
    min-height:100vh;
    background:#0b1220;
    color:white;
    padding:14px 14px 92px 14px;
    box-sizing:border-box;
}

.cult-topbar{
    position:sticky;
    top:0;
    z-index:20;
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:12px;
    padding:12px;
    border-radius:18px;
    background:rgba(21,101,192,.95);
    box-shadow:0 6px 18px rgba(0,0,0,.25);
}

.cult-topbar button{
    width:44px;
    height:44px;
    border:none;
    border-radius:50%;
    background:rgba(255,255,255,.18);
    color:white;
    font-size:22px;
    font-weight:bold;
}

.cult-topbar div{
    flex:1;
    text-align:center;
}

.cult-topbar strong{
    display:block;
    font-size:18px;
}

.cult-topbar span{
    display:block;
    opacity:.9;
    font-size:14px;
}

.cult-song-body{
    max-width:820px;
    margin:22px auto 0 auto;
}

.cult-song-body h1{
    font-size:34px;
    line-height:1.1;
    margin:12px 0 4px;
    text-align:center;
}

.cult-artist{
    text-align:center;
    opacity:.78;
    margin:0 0 16px;
}

.cult-tone-control{
    display:flex;
    justify-content:center;
    align-items:center;
    gap:18px;
    margin:18px auto;
}

.cult-tone-control button{
    width:54px;
    height:54px;
    border:none;
    border-radius:50%;
    background:#1565c0;
    color:white;
    font-size:24px;
    font-weight:bold;
}

.cult-tone-control span{
    min-width:78px;
    text-align:center;
    font-size:32px;
    font-weight:800;
    padding:10px 16px;
    border-radius:18px;
    background:rgba(255,255,255,.12);
}

.cult-chords{
    background:rgba(255,255,255,.08);
    border-radius:14px;
    padding:12px;
    line-height:1.5;
}

.cult-lyrics{
    white-space:pre-wrap;
    word-wrap:break-word;
    overflow-wrap:break-word;
    line-height:1.55;
    color:white;
    font-family:Arial, sans-serif;
    background:transparent;
    padding:6px 0;
}

.cult-bottom-bar{
    position:fixed;
    left:10px;
    right:10px;
    bottom:12px;
    z-index:30;
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:8px;
    padding:10px;
    border-radius:22px;
    background:rgba(15,23,42,.96);
    box-shadow:0 8px 24px rgba(0,0,0,.45);
}

.cult-bottom-bar button{
    flex:1;
    min-height:48px;
    border:none;
    border-radius:16px;
    background:#1565c0;
    color:white;
    font-size:18px;
    font-weight:bold;
}

.cult-quick-list{
    position:fixed;
    left:14px;
    right:14px;
    top:86px;
    z-index:40;
    max-height:65vh;
    overflow:auto;
    padding:16px;
    border-radius:20px;
    background:#111827;
    box-shadow:0 12px 30px rgba(0,0,0,.55);
}

.cult-quick-list.hidden{
    display:none;
}

.cult-quick-list h3{
    margin-top:0;
    text-align:center;
}

.cult-list-item{
    padding:14px;
    margin:8px 0;
    border-radius:14px;
    background:rgba(255,255,255,.08);
    font-weight:bold;
}

.cult-list-item span{
    float:right;
    opacity:.85;
}

.cult-list-item.active{
    background:#1565c0;
}

.tone-pill{
    display:inline-block;
    margin:8px 0;
    padding:8px 12px;
    border-radius:999px;
    background:#e3f2fd;
    color:#0d47a1;
    font-weight:bold;
}

.dark-mode .tone-pill{
    background:#263238;
    color:#90caf9;
}

.plan-row-actions{
    display:flex;
    flex-wrap:wrap;
    gap:6px;
    margin-top:8px;
}


/* ================= AdorApp v1.8 REAL - Modo Culto PRO ================= */

body.cult-active header,
body.cult-active main > input,
body.cult-active main > select,
body.cult-active #favoritesFilter,
body.cult-active #plannerBtn {
    display: none !important;
}

body.cult-active main {
    padding: 0;
    margin: 0;
    max-width: none;
}

.cult-pro-screen {
    min-height: 100vh;
    padding: 18px;
    background: #0f172a;
    color: white;
}

.cult-pro-top {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    background: rgba(15, 23, 42, .95);
    padding: 12px 0;
}

.cult-pro-top button,
.cult-pro-controls button,
.cult-pro-tone button,
.cult-list button {
    border: none;
    border-radius: 12px;
    padding: 12px 14px;
    font-weight: bold;
    background: #2563eb;
    color: white;
}

.cult-pro-title {
    text-align: center;
    margin: 28px 0 18px;
}

.cult-pro-title h1 {
    font-size: 42px;
    line-height: 1.05;
    margin: 0;
}

.cult-pro-title p {
    opacity: .8;
    font-size: 18px;
}

.cult-pro-tone {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 18px;
    margin: 18px 0;
}

.cult-pro-tone strong {
    font-size: 44px;
    background: white;
    color: #0f172a;
    border-radius: 16px;
    padding: 8px 28px;
}

.cult-pro-chords {
    font-size: 20px;
    background: rgba(255,255,255,.1);
    padding: 12px;
    border-radius: 14px;
}

.cult-pro-lyrics {
    white-space: pre-wrap;
    font-family: monospace;
    line-height: 1.55;
    margin-bottom: 100px;
}

.cult-pro-controls {
    position: fixed;
    left: 10px;
    right: 10px;
    bottom: 10px;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
    background: rgba(15, 23, 42, .96);
    padding: 10px;
    border-radius: 18px;
    box-shadow: 0 -4px 16px rgba(0,0,0,.35);
}

.cult-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 20px;
}

.cult-list button {
    text-align: left;
    font-size: 18px;
    background: rgba(255,255,255,.12);
}



/* ================= Editor de cantos ================= */

