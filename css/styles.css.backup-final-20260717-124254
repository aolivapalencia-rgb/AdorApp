.chordpro-lyrics {
  font-family: "Courier New", monospace;
  font-size: 18px;
  line-height: 1.35;
  white-space: pre;
  overflow-x: auto;
}

.song-section-title {
  margin-top: 22px;
  margin-bottom: 10px;
  font-weight: 900;
  font-size: 20px;
  text-transform: uppercase;
}

.dark-mode .chordpro-chords,
body.pro-song-editor-mode .chordpro-chords {
  color: #64b5f6;
}

/* ===== Vista exacta de cantos ===== */
.exact-chart {
  font-family: "Courier New", monospace !important;
  font-size: 18px !important;
  line-height: 1.35 !important;
  white-space: pre !important;
  overflow-x: auto !important;
  overflow-y: visible !important;
  background: transparent !important;
  color: inherit !important;
  margin: 20px 0 !important;
  padding: 0 !important;
}

/* ===== AdorApp modo llenar fichas ===== */

/* ocultar opciones que ya no usaremos */
#addSongBtn,
#importImageBtn,
#imageImportInput,
#importImageInput {
  display: none !important;
}

/* tarjetas pequeñas tipo himnario */
.song-card {
  padding: 14px 18px !important;
  margin: 10px 0 !important;
  border-radius: 14px !important;
  min-height: auto !important;
}

.song-card h2,
.song-card h3 {
  font-size: 22px !important;
  margin: 0 0 4px 0 !important;
}

.song-card p {
  font-size: 15px !important;
  margin: 2px 0 !important;
}

.song-card .favorite-btn {
  font-size: 26px !important;
  top: 10px !important;
  right: 14px !important;
}

/* hoja de edición */
.edit-sheet {
  background: white;
  padding: 24px;
  border-radius: 24px;
  margin: 20px auto;
  max-width: 760px;
}

.dark-mode .edit-sheet {
  background: #1f1f1f;
  color: white;
}

.edit-sheet label {
  display: block;
  font-weight: 900;
  font-size: 22px;
  margin-top: 18px;
  margin-bottom: 8px;
}

.edit-sheet input,
.edit-sheet textarea {
  width: 100%;
  box-sizing: border-box;
  font-size: 20px;
  padding: 14px;
  border-radius: 12px;
  border: 1px solid #ccc;
}

.edit-sheet textarea {
  min-height: 70vh;
  font-family: "Courier New", monospace;
  white-space: pre;
  overflow: auto;
  resize: vertical;
  line-height: 1.35;
}

.edit-actions {
  display: flex;
  gap: 10px;
  margin-top: 18px;
}

.edit-actions button {
  flex: 1;
  padding: 16px;
  border: none;
  border-radius: 14px;
  font-size: 20px;
  font-weight: 900;
  color: white;
}

.save-edit-btn {
  background: #1b8f3a;
}

.cancel-edit-btn {
  background: #555;
}

.delete-edit-btn {
  background: #d32f2f;
}

.exact-chart {
  font-family: "Courier New", monospace !important;
  white-space: pre !important;
  overflow-x: auto !important;
  line-height: 1.35 !important;
  font-size: 18px !important;
  background: transparent !important;
}

/* ===== Botón para editar las 125 fichas existentes ===== */

.edit-existing-song-btn {
  display: block;
  width: calc(100% - 32px);
  max-width: 620px;
  margin: 16px auto 24px;
  padding: 17px 20px;
  border: none;
  border-radius: 15px;
  background: #1f6fc7;
  color: #fff;
  font-size: 21px;
  font-weight: 900;
  cursor: pointer;
  box-shadow: 0 6px 15px rgba(0, 0, 0, .18);
}

.edit-existing-song-btn:active {
  transform: scale(.98);
}

/* Editor manual tipo hoja */
.edit-sheet textarea#editLyrics {
  min-height: 70vh !important;
  height: 70vh !important;
  font-family: "Courier New", monospace !important;
  font-size: 18px !important;
  line-height: 1.4 !important;
  white-space: pre !important;
  overflow: auto !important;
  overflow-wrap: normal !important;
  word-break: normal !important;
  tab-size: 4;
}

/* Evitar que esta hoja cambie obligatoriamente a modo oscuro */
.edit-sheet {
  background: #fff !important;
  color: #111 !important;
}

.edit-sheet input,
.edit-sheet textarea {
  background: #fff !important;
  color: #111 !important;
}

/* =========================================================
   ADORAPP — FICHAS COMPACTAS Y EDITOR MANUAL DEFINITIVO
   ========================================================= */

/* Eliminar herramientas que ya no se utilizarán */
#addSongBtn,
#importImageBtn,
#imageImportInput,
#importImageInput,
button[onclick*="openAddSong"],
button[onclick*="openImage"],
button[onclick*="ImageImport"] {
  display: none !important;
}

/* Tarjetas pequeñas tipo himnario */
.song-card {
  position: relative !important;
  min-height: 0 !important;
  margin: 7px 12px !important;
  padding: 13px 54px 13px 18px !important;
  border-radius: 12px !important;
  text-align: left !important;
}

.song-card h2,
.song-card h3 {
  margin: 0 0 3px !important;
  font-size: 19px !important;
  line-height: 1.2 !important;
}

.song-card p {
  margin: 0 !important;
  font-size: 13px !important;
  line-height: 1.3 !important;
}

.song-card .favorite-btn {
  top: 50% !important;
  right: 14px !important;
  transform: translateY(-50%) !important;
  font-size: 23px !important;
}

/* Vista de la ficha */
.ador-song-detail {
  position: relative;
}

.ador-detail-topbar {
  display: grid;
  grid-template-columns: 1fr 1fr auto;
  align-items: center;
  gap: 10px;
}

.ador-detail-topbar button {
  margin: 0 !important;
}

.edit-existing-song-btn {
  display: block !important;
  width: 100% !important;
  margin: 18px 0 28px !important;
  padding: 17px 20px !important;
  border: 0 !important;
  border-radius: 15px !important;
  background: #1f6fc7 !important;
  color: #fff !important;
  font-size: 21px !important;
  font-weight: 900 !important;
  box-shadow: 0 6px 15px rgba(0, 0, 0, .16);
}

/* Mostrar exactamente lo escrito */
.ador-exact-lyrics {
  width: 100% !important;
  box-sizing: border-box !important;
  margin: 24px 0 0 !important;
  padding: 0 0 20px !important;
  border: 0 !important;
  background: transparent !important;
  color: inherit !important;
  font-family: "Courier New", Courier, monospace !important;
  line-height: 1.4 !important;
  white-space: pre !important;
  overflow-x: auto !important;
  overflow-y: visible !important;
  overflow-wrap: normal !important;
  word-break: normal !important;
  tab-size: 4 !important;
}

/* Hoja manual de edición */
.ador-edit-sheet {
  width: calc(100% - 24px);
  max-width: 820px;
  margin: 18px auto 50px;
  padding: 22px;
  box-sizing: border-box;
  border-radius: 22px;
  background: #fff;
  color: #111;
  box-shadow: 0 7px 24px rgba(0, 0, 0, .13);
}

.ador-edit-header {
  display: flex;
  align-items: center;
  gap: 18px;
  margin-bottom: 12px;
}

.ador-edit-header h2 {
  margin: 0;
  font-size: 29px;
}

.ador-edit-back {
  border: 0;
  border-radius: 12px;
  padding: 13px 17px;
  background: #1f6fc7;
  color: #fff;
  font-size: 17px;
  font-weight: 800;
}

.ador-edit-help {
  margin: 10px 0 22px;
  padding: 14px;
  border-radius: 12px;
  background: #e5f2ff;
  color: #18364f;
  font-size: 15px;
  line-height: 1.4;
}

.ador-edit-sheet label {
  display: block;
  margin: 18px 0 7px;
  font-size: 18px;
  font-weight: 900;
}

.ador-edit-sheet input,
.ador-edit-sheet textarea {
  display: block;
  width: 100%;
  box-sizing: border-box;
  border: 1px solid #b8bec7;
  border-radius: 12px;
  background: #fff !important;
  color: #111 !important;
  font-size: 18px;
  outline: none;
}

.ador-edit-sheet input {
  padding: 14px 15px;
}

.ador-edit-sheet textarea {
  height: 72vh !important;
  min-height: 560px !important;
  padding: 17px !important;
  font-family: "Courier New", Courier, monospace !important;
  font-size: 18px !important;
  line-height: 1.4 !important;
  white-space: pre !important;
  overflow: auto !important;
  overflow-wrap: normal !important;
  word-break: normal !important;
  resize: vertical !important;
  tab-size: 4 !important;
}

.ador-edit-sheet input:focus,
.ador-edit-sheet textarea:focus {
  border-color: #1f6fc7;
  box-shadow: 0 0 0 3px rgba(31, 111, 199, .14);
}

.ador-edit-actions {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 12px;
  margin-top: 18px;
}

.ador-edit-actions button {
  min-height: 56px;
  border: 0;
  border-radius: 14px;
  color: #fff;
  font-size: 18px;
  font-weight: 900;
}

.ador-cancel-button {
  background: #555;
}

.ador-save-button {
  background: #18843a;
}

.ador-save-notice {
  position: fixed;
  left: 50%;
  bottom: 28px;
  z-index: 20000;
  transform: translateX(-50%);
  width: max-content;
  max-width: calc(100% - 40px);
  padding: 14px 20px;
  border-radius: 14px;
  background: #18843a;
  color: #fff;
  font-size: 16px;
  font-weight: 900;
  box-shadow: 0 8px 25px rgba(0, 0, 0, .27);
}

/* El editor permanece claro aunque la aplicación esté oscura */
.dark-mode .ador-edit-sheet {
  background: #fff !important;
  color: #111 !important;
}

@media (max-width: 520px) {
  .ador-edit-sheet {
    width: calc(100% - 14px);
    padding: 15px;
  }

  .ador-edit-header h2 {
    font-size: 24px;
  }

  .ador-edit-sheet textarea {
    font-size: 17px !important;
  }

  .ador-detail-topbar {
    grid-template-columns: 1fr 1fr;
  }

  .ador-detail-topbar .detail-heart {
    position: absolute;
    top: 90px;
    right: 16px;
  }
}
